# Discord Bot Token (จาก https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# BattleMetrics API Key (ไม่จำเป็น ถ้าไม่ใส่จะใช้ Public API แทน)
# สามารถใส่ถ้าต้องการ Rate Limit ที่สูงขึ้น)
BATTLEMETRICS_API_KEY=

# SCUM Server ID ที่ต้องการติดตาม (จาก BattleMetrics URL)
SERVER_ID=your_scum_server_id_here

# ความถี่ในการอัปเดตสถานะใต้ชื่อบอท (หน่วย: นาที)
PRESENCE_UPDATE_INTERVAL=5

# หมายเหตุ: หลังจากรัน /setup แล้ว ข้อมูล Category/Channel จะถูกบันทึกใน data/setup.json โดยอัตโนมัติ